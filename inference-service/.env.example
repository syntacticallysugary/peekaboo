# Command Module (central person registry & webhook dispatch)
COMMAND_MODULE_URL=http://192.168.x.x:8081

# GPU device ID (usually 0 for single-GPU systems)
INFERENCE_GPU_ID=0

# Face recognition model pack (buffalo_l, buffalo_s, etc.)
INFERENCE_MODEL_PACK=buffalo_l

# Directory containing ONNX models (typically /models in Docker)
INFERENCE_MODELS_DIR=/models

# YOLOv8 detection model input size (usually 640)
INFERENCE_MAX_DETECT_SIZE=640

# Face similarity threshold for recognition (0.0-1.0)
INFERENCE_RECOGNITION_THRESHOLD=0.40

# Logging level (debug, info, warning, error)
INFERENCE_LOG_LEVEL=info
