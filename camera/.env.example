# WiFi credentials (provisioned into firmware at build time)
WIFI_SSID=YourNetworkName
WIFI_PASSWORD=YourWifiPassword

# Pre-shared key for MQTT command authentication
SECRET_PSK=your_mqtt_psk_here

# MQTT broker (for receiving reboot/restart/OTA commands)
MQTT_BROKER_HOST=192.168.x.x
MQTT_PASSWORD=your_mqtt_password_here

# Inference service (Jetson running person detection + face recognition)
JETSON_URL=http://192.168.x.x:8001

# Command module (central registry, person DB, alert dispatch)
COMMAND_MODULE_URL=http://192.168.x.x:8081
