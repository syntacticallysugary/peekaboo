#pragma once

// WiFi Configuration
// Set these to your network credentials before building
#define WIFI_SSID "YOUR_NETWORK_NAME"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Command Module (Central Dashboard & Person Registry)
#define COMMAND_MODULE_URL "http://192.168.x.x:8081"

// Jetson Inference Service (Person Detection & Face Recognition)
#define JETSON_URL "http://192.168.x.x:8001"

// API Bearer Token
// Used to authenticate camera requests to firmware OTA and command module endpoints
// Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#define SECRET_PSK "YOUR_SECURE_RANDOM_TOKEN_HERE"

// MQTT Broker (Mosquitto on Command Module Host)
#define MQTT_BROKER_HOST "192.168.x.x"
#define MQTT_BROKER_PORT 8883

// MQTT Camera Password
// Per-device credentials are set via camera/.env: MQTT_PASSWORD_<CAMERA_ID>
// This is injected by the pre-build script; hardcoded here as fallback
#define MQTT_PASSWORD "YOUR_MQTT_PASSWORD_HERE"
