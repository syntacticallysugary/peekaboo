# Google Cloud / Firestore configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_SA_KEY_PATH=/path/to/gcp-sa.json
# For local development without GCP: FIRESTORE_EMULATOR_HOST=localhost:8080

# MQTT broker (Mosquitto — camera control channel)
# Broker password for the "command-module" user (generate via tools/gen-mqtt-passwd.sh)
MQTT_COMMAND_PASSWORD=your_mqtt_password_here

# Inference service (Jetson Orin Nano running person detection + face recognition)
INFERENCE_NODE_URL=http://192.168.x.x:8001

# Storage backend (local disk or S3-compatible)
STORAGE_BACKEND=local
RECORDINGS_PATH=./data/recordings

# Command Module (FastAPI, port 8081)
PORT=8081
SECRET_KEY=generate_a_secure_random_string_here
