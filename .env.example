# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
# Path to service account JSON key (used by docker-compose volume mount)
GCP_SA_KEY_PATH=/path/to/gcp-sa.json
# Set FIRESTORE_EMULATOR_HOST=localhost:8080 for local development without GCP

# MQTT control channel (camera reboot/diagnostics)
# The command-module connects over the loopback listener; cameras use TLS on 8883.
# MQTT_COMMAND_PASSWORD is the broker password for the "command-module" user,
# generated by tools/gen-mqtt-passwd.sh.
MQTT_COMMAND_PASSWORD=generated_by_gen-mqtt-passwd.sh

# Inference Node configuration (Jetson Orin Nano)
INFERENCE_NODE_URL=http://<JETSON_IP>:8001

# Storage configuration
STORAGE_BACKEND=local
RECORDINGS_PATH=./data/recordings

# Command Module settings
COMMAND_MODULE_PORT=8000
SECRET_KEY=generate_a_secure_random_string_here
